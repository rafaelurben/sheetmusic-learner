{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.20.0",
    "generators": {
      "v1": {
        "generatorName": "typescript-fetch",
        "output": "./src/api/generated/openapi",
        "inputSpec": "../openapi.yml",
        "globalProperty": {
          "apiDocs": false,
          "modelDocs": false
        },
        "additionalProperties": {}
      }
    }
  }
}
